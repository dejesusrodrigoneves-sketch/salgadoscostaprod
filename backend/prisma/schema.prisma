generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Empresa {
  id              Int               @id @default(autoincrement())
  nome            String
  slug            String            @unique
  logo            String?
  createdAt       DateTime          @default(now()) @map("criado_em")

  // Store contact
  telefone        String?
  endereco        String?
  numero          String?
  bairro          String?
  cidade          String?
  estado          String?
  cep             String?
  latitude        Decimal?          @db.Decimal(10, 7)
  longitude       Decimal?          @db.Decimal(10, 7)
  descricao       String?

  // Store operating hours
  openingTime     String?           @map("opening_time")
  closingTime     String?           @map("closing_time")
  workingDays     Json              @default("[]") @map("working_days")
  isOpen          Boolean           @default(true) @map("is_open")
  manualOverride  Boolean           @default(false) @map("manual_override")

  usuarios        Usuario[]
  produtos        Produto[]
  categorias      Categoria[]
  pedidos         Pedido[]
  entregadores    Entregador[]
  entregasDiarias EntregaDiaria[]
  caixaDiario     CaixaDiario[]
  horarios        Horario[]
  counters        Counter[]
  cupons          Cupom[]
  clientes        Cliente[]
  whatsappInstances WhatsAppInstance[]

  @@map("empresas")
}

model Categoria {
  id         Int       @id @default(autoincrement())
  empresaId  Int       @map("empresa_id")
  empresa    Empresa   @relation(fields: [empresaId], references: [id])
  nome       String
  type       Int?      // mapping to legacy type (1-6)
  createdAt  DateTime  @default(now()) @map("criado_em")
  produtos   Produto[]

  @@unique([empresaId, nome])
  @@map("categorias")
}

model Usuario {
  id           Int      @id @default(autoincrement())
  empresaId    Int      @map("empresa_id")
  empresa      Empresa  @relation(fields: [empresaId], references: [id])
  username     String
  passwordHash String   @map("password_hash")
  lojaNome     String?  @map("loja_nome")
  role         String   @default("user")
  createdAt    DateTime @default(now()) @map("criado_em")

  @@unique([empresaId, username])
  @@map("usuarios")
}

model Produto {
  id             Int           @id @default(autoincrement())
  empresaId      Int           @map("empresa_id")
  empresa        Empresa       @relation(fields: [empresaId], references: [id])
  type           Int
  name           String
  description    String?
  price          Decimal       @db.Decimal(10, 2)
  img            String?
  status         String        @default("active")
  congelado      Boolean       @default(false)
  controlaEstoque Boolean      @default(false) @map("controla_estoque")
  estoqueAtual   Int           @default(0) @map("estoque_atual")
  estoqueMinimo  Int           @default(0) @map("estoque_minimo")
  hideWhenOutOfStock Boolean   @default(true) @map("hide_when_out_of_stock")
  lastPrice      Decimal?      @db.Decimal(10, 2) @map("last_price")
  categoryId     Int?          @map("category_id")
  category       Categoria?    @relation(fields: [categoryId], references: [id])
  itens          ItensPedido[]

  @@map("produtos")
}

model Pedido {
  id               String          @id
  empresaId        Int             @map("empresa_id")
  empresa          Empresa         @relation(fields: [empresaId], references: [id])
  clienteNome      String          @map("cliente_nome")
  clienteWhatsapp  String?         @map("cliente_whatsapp")
  clienteEndereco  String?         @map("cliente_endereco")
  clienteNumero    String?         @map("cliente_numero")
  clienteBairro    String?         @map("cliente_bairro")
  clienteCep       String?         @map("cliente_cep")
  clienteReferencia String?        @map("cliente_referencia")
  tipoEntrega      String          @default("delivery") @map("tipo_entrega")
  formaPagamento   String?         @map("forma_pagamento")
  troco            Decimal?        @db.Decimal(10, 2)
  status           String          @default("pendente")
  valoresItens     Decimal?        @db.Decimal(10, 2) @map("valores_itens")
  taxasEntrega     Decimal?        @db.Decimal(10, 2) @map("taxas_entrega")
  taxasCartao      Decimal?        @db.Decimal(10, 2) @map("taxas_cartao")
  desconto         Decimal?        @db.Decimal(10, 2)
  total            Decimal?        @db.Decimal(10, 2)
  entregadorId     String?         @map("entregador_id")
  lat              Decimal?        @db.Decimal(10, 7)
  lon              Decimal?        @db.Decimal(10, 7)
  createdAt        DateTime        @default(now()) @map("criado_em")
  finalizadoEm     DateTime?       @map("finalizado_em")
  itens            ItensPedido[]

  @@map("pedidos")
}

model ItensPedido {
  id        Int      @id @default(autoincrement())
  pedidoId  String   @map("pedido_id")
  pedido    Pedido   @relation(fields: [pedidoId], references: [id])
  produtoId Int      @map("produto_id")
  produto   Produto  @relation(fields: [produtoId], references: [id])
  quantidade Int
  precoUnitario Decimal? @db.Decimal(10, 2) @map("preco_unitario")
  sabores   String?

  @@map("itens_pedido")
}

model Entregador {
  id        Int              @id @default(autoincrement())
  empresaId Int              @map("empresa_id")
  empresa   Empresa          @relation(fields: [empresaId], references: [id])
  nome      String
  endereco  String?
  whatsapp  String?
  chavePix  String?          @map("chave_pix")
  ativo     Boolean          @default(true)
  createdAt DateTime         @default(now()) @map("criado_em")

  @@map("entregadores")
}

model EntregaDiaria {
  id            Int        @id @default(autoincrement())
  empresaId     Int        @map("empresa_id")
  empresa       Empresa    @relation(fields: [empresaId], references: [id])
  data          DateTime
  entregadorId  Int        @map("entregador_id")
  pedidoId      String     @map("pedido_id")
  valor         Decimal?   @db.Decimal(10, 2)
  createdAt     DateTime   @default(now()) @map("criado_em")

  @@map("entregas_diarias")
}

model CaixaDiario {
  id               Int       @id @default(autoincrement())
  empresaId        Int       @map("empresa_id")
  empresa          Empresa   @relation(fields: [empresaId], references: [id])
  data             DateTime
  valorInicial     Decimal?  @db.Decimal(10, 2) @map("valor_inicial")
  totalDinheiro    Decimal?  @default(0) @db.Decimal(10, 2) @map("total_dinheiro")
  totalPix         Decimal?  @default(0) @db.Decimal(10, 2) @map("total_pix")
  totalDebito      Decimal?  @default(0) @db.Decimal(10, 2) @map("total_debito")
  totalCredito     Decimal?  @default(0) @db.Decimal(10, 2) @map("total_credito")
  totalPedidos     Decimal?  @default(0) @db.Decimal(10, 2) @map("total_pedidos")
  quantidadePedidos Int?     @default(0) @map("quantidade_pedidos")
  status           String    @default("aberto")
  abertoEm         DateTime? @map("aberto_em")
  fechadoEm        DateTime? @map("fechado_em")

  @@map("caixa_diario")
}

model Horario {
  id        Int      @id @default(autoincrement())
  empresaId Int      @unique @map("empresa_id")
  empresa   Empresa  @relation(fields: [empresaId], references: [id])
  dia       String
  fechado   Boolean  @default(false)
  inicio    String?
  fim       String?

  @@map("horarios")
}

model Counter {
  nome       String
  empresaId  Int    @map("empresa_id")
  empresa    Empresa @relation(fields: [empresaId], references: [id])
  lastValue  Int    @default(0) @map("last_value")

  @@id([nome, empresaId])
  @@map("counters")
}

model Cliente {
  id             Int      @id @default(autoincrement())
  empresaId      Int      @map("empresa_id")
  empresa        Empresa  @relation(fields: [empresaId], references: [id])
  nome           String
  telefone       String
  endereco       String?
  numero         String?
  bairro         String?
  cep            String?
  pontoReferencia String? @map("ponto_referencia")
  passwordHash   String?  @map("password_hash")
  createdAt      DateTime @default(now()) @map("criado_em")

  @@unique([empresaId, telefone])
  @@map("clientes")
}

model Cupom {
  codigo    String   @id
  empresaId Int      @map("empresa_id")
  empresa   Empresa  @relation(fields: [empresaId], references: [id])
  desconto  Decimal  @db.Decimal(10, 2)
  usado     Boolean  @default(false)

  @@map("cupons")
}

model WhatsAppInstance {
  id               Int       @id @default(autoincrement())
  empresaId        Int       @map("empresa_id")
  empresa          Empresa   @relation(fields: [empresaId], references: [id])
  instanceId       String    @map("instance_id")
  connectionStatus String    @default("disconnected") @map("connection_status")
  phoneNumber      String?   @map("phone_number")
  qrCode           String?   @map("qr_code")
  isActive         Boolean   @default(false) @map("is_active")
  createdAt        DateTime  @default(now()) @map("criado_em")
  updatedAt        DateTime  @updatedAt @map("atualizado_em")

  @@unique([empresaId, instanceId])
  @@map("whatsapp_instances")
}